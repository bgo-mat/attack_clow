{
  "meta": {
    "lastTouchedVersion": "2026.3.13"
  },
  "auth": {
    "profiles": {
      "ollama:default": {
        "provider": "ollama",
        "mode": "none"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "spectre",
        "fallbacks": []
      },
      "models": {
        "spectre": {
          "alias": "Spectre (dolphin-llama3.1:70b uncensored)"
        }
      },
      "workspace": "/root/.openclaw/workspace",
      "memorySearch": {
        "enabled": false
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": {
    "profile": "full"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18790,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18790",
        "http://127.0.0.1:18790",
        "http://__VPS_IP__:18790",
        "https://__VPS_IP__"
      ]
    },
    "auth": {
      "mode": "password",
      "token": "__TOKEN__",
      "password": "__PASSWORD__"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "providers": {
    "ollama": {
      "baseUrl": "http://127.0.0.1:11434/v1",
      "api": "openai-completions"
    }
  }
}
