{
  "meta": {
    "lastTouchedVersion": "2026.3.13"
  },
  "auth": {
    "profiles": {
      "openai-compat:default": {
        "provider": "openai-compat",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-compat/spectre:latest",
        "fallbacks": []
      },
      "models": {
        "openai-compat/spectre:latest": {
          "alias": "Spectre (dolphin-llama3:70b uncensored)"
        }
      },
      "workspace": "/root/.openclaw/workspace",
      "memorySearch": {
        "enabled": false
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": {
    "profile": "full"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18790,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18790",
        "http://127.0.0.1:18790",
        "http://__VPS_IP__:18790",
        "https://__VPS_IP__",
        "https://__VPS_IP__:443"
      ]
    },
    "auth": {
      "mode": "password",
      "token": "__TOKEN__",
      "password": "__PASSWORD__"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  }
}
